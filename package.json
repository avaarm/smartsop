{
  "name": "smartsop",
  "version": "1.0.0",
  "description": "AI-powered GMP documentation platform for pharma & biotech",
  "author": "SmartSOP <hello@smartsop.io>",
  "license": "UNLICENSED",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:desktop": "electron .",
    "build": "ng build",
    "build:frontend": "ng build --configuration production",
    "build:backend": "bash scripts/build-backend.sh",
    "build:app": "bash scripts/build-app.sh",
    "build:app:mac": "bash scripts/build-app.sh --mac",
    "build:app:win": "bash scripts/build-app.sh --win",
    "build:app:linux": "bash scripts/build-app.sh --linux",
    "build:app:all": "bash scripts/build-app.sh --all",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:smartsop": "node dist/smartsop/server/server.mjs"
  },
  "dependencies": {
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/platform-server": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@angular/ssr": "^18.2.8",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.8",
    "@angular/cli": "^18.2.8",
    "@angular/compiler-cli": "^18.2.0",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.18.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.5.2"
  }
}
